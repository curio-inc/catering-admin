# デモ提供用（Supabase・パスワード不要でサンプル注文を表示）
USE_MOCK_DATA=true
# お客様向け注文ページ: /order（USE_MOCK_DATA=true のときのみ公開）
# Vercel: .env.production でデモ既定値あり。本番運用時は Project Settings → Environment Variables で USE_MOCK_DATA を外すか false に設定

# 本番運用時のみ（USE_MOCK_DATA を外した場合に必須）
# ADMIN_PASSWORD=your-admin-password
# SESSION_SECRET=change-this-to-a-long-random-string-32chars-min

# 画面表示名（ログイン画面は NEXT_PUBLIC_ も必要）
# APP_BRAND_NAME=サンプル
# NEXT_PUBLIC_APP_BRAND_NAME=サンプル
# デモ画面ヘッダーの「← LPに戻る」リンク先（任意）
# NEXT_PUBLIC_DEMO_BACK_URL=https://example.com/

# Supabase（本番データ利用時。USE_MOCK_DATA=true のときは不要）
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# 省略形でも可（lib/supabase-admin.ts が読みます）
# SUPABASE_URL=
# SUPABASE_SECRET_KEY=

# 請求書「送付」でメール送信する場合（任意）
# RESEND_API_KEY=
# RESEND_FROM=order@demo-catering.example

# 請求書（印刷）の自社情報・振込先（未設定時はデモ用プレースホルダ）
# INVOICE_ISSUER_COMPANY=株式会社サンプル
# INVOICE_ISSUER_REP= 任意。空のままなら請求書に担当行は出しません
# INVOICE_ISSUER_POSTAL=
# INVOICE_ISSUER_ADDRESS=
# INVOICE_ISSUER_TEL=
# INVOICE_ISSUER_EMAIL=
# 改行区切りで複数行（銀行・支店・口座種別・口座番号・口座名義カナなど）
# INVOICE_BANK_LINES=
# INVOICE_PAYMENT_DUE_DAYS=30
# INVOICE_TRANSFER_FEE_NOTE=
