# Supabase（注文フォーム custom-order-sheet と同一プロジェクト）
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# 省略形でも可（lib/supabase-admin.ts が読みます）
# SUPABASE_URL=
# SUPABASE_SECRET_KEY=

# 請求書「送付」でメール送信する場合（任意）
# RESEND_API_KEY=
# RESEND_FROM=order@spams-good.com
