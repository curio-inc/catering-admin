# 管理画面ログイン（必須）
ADMIN_PASSWORD=your-admin-password
# 32文字以上のランダムな文字列（例: openssl rand -hex 32 で生成）
SESSION_SECRET=change-this-to-a-long-random-string-32chars-min

# Supabase（注文フォーム custom-order-sheet と同一プロジェクト）
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# 省略形でも可（lib/supabase-admin.ts が読みます）
# SUPABASE_URL=
# SUPABASE_SECRET_KEY=

# 請求書「送付」でメール送信する場合（任意）
# RESEND_API_KEY=
# RESEND_FROM=order@spams-good.com

# 請求書（印刷）の自社情報・振込先（未設定時はプレースホルダ）
# INVOICE_ISSUER_COMPANY=
# INVOICE_ISSUER_REP= 任意。空のままなら請求書に担当行は出しません
# INVOICE_ISSUER_POSTAL=
# INVOICE_ISSUER_ADDRESS=
# INVOICE_ISSUER_TEL=
# INVOICE_ISSUER_EMAIL=
# 改行区切りで複数行（銀行・支店・口座種別・口座番号・口座名義カナなど）
# INVOICE_BANK_LINES=
# INVOICE_PAYMENT_DUE_DAYS=30
# INVOICE_TRANSFER_FEE_NOTE=
